#!/usr/bin/env bash
# Husky commit-msg hook — validate conventional commit format
# Installed by next-standards installer into .husky/commit-msg

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Conventional Commits regex
PATTERN='^(feat|fix|refactor|chore|docs|test|perf|release|hotfix)(\([a-z0-9-]+\))?: .{1,100}$'

# Allow merge commits
if echo "$COMMIT_MSG" | head -1 | grep -qE '^Merge '; then
  exit 0
fi

# Allow Co-Authored-By lines (check first line only)
FIRST_LINE=$(echo "$COMMIT_MSG" | head -1)

if ! echo "$FIRST_LINE" | grep -qE "$PATTERN"; then
  echo "❌ Commit message doesn't match Conventional Commits format."
  echo ""
  echo "Expected: type(scope): description"
  echo "  Types: feat, fix, refactor, chore, docs, test, perf, release, hotfix"
  echo "  Example: feat(auth): add password reset flow"
  echo ""
  echo "Your message: $FIRST_LINE"
  exit 1
fi
